#!/usr/bin/env bash

reset=$(printf '\033[0m')

# Gruvbox dark palette (truecolor)
rgb() { printf '\033[38;2;%s;%s;%sm' "$1" "$2" "$3"; }

fg0=$(rgb 235 219 178)   # #ebdbb2
fg1=$(rgb 235 219 178)
gray=$(rgb 146 131 116)  # #928374

red=$(rgb 251 73 52)     # #fb4934
green=$(rgb 184 187 38)  # #b8bb26
yellow=$(rgb 250 189 47) # #fabd2f
blue=$(rgb 131 165 152)  # #83a598
purple=$(rgb 211 134 155)# #d3869b
aqua=$(rgb 142 192 124)  # #8ec07c
orange=$(rgb 254 128 25) # #fe8019

os_icon="󰍹"
ker_icon=""
up_icon="󱎫"
pkg_icon="󰏖"
inst_icon="󰄾"
gpu_icon=""
cpu_icon=""
ram_icon=""
disk_icon="󰋊"

user=$(id -un | tr '[:upper:]' '[:lower:]')
host="$(hostname --short)"
os="$(awk -F= '/^PRETTY_NAME=/{gsub(/"/,"",$2);print $2}' /etc/os-release 2>/dev/null || echo "Unknown")"
kernel="$(uname -r 2>/dev/null || echo "Unknown")"
uptime=$(uptime -p 2>/dev/null | sed 's/up //;s/ days\?/d/;s/ hours\?/h/;s/ minutes\?/m/' | tr -d ',')

install_days="unknown"
if [ -d /lost+found ]; then
  install_date=$(stat -c %W /lost+found 2>/dev/null)
  if [ "$install_date" -gt 0 ] 2>/dev/null; then
    install_days=$((($(date +%s) - install_date) / 86400))
  fi
fi

detect_pkgs() {
  if command -v xbps-query >/dev/null; then
    xbps-query -l | wc -l
  elif command -v dpkg >/dev/null; then
    dpkg -l | grep -c '^ii'
  elif command -v pacman >/dev/null; then
    pacman -Qq | wc -l
  elif command -v rpm >/dev/null; then
    rpm -qa | wc -l
  elif command -v dnf >/dev/null; then
    dnf list installed | wc -l
  elif command -v zypper >/dev/null; then
    zypper se -i | wc -l
  elif command -v apk >/dev/null; then
    apk info | wc -l
  else
    echo 0
  fi
}

detect_pkg_manager() {
  for cmd in xbps-query dpkg pacman rpm dnf zypper apk; do
    if command -v "$cmd" >/dev/null; then
      case "$cmd" in
        xbps-query) echo "xbps" ;;
        *) echo "$cmd" ;;
      esac
      return
    fi
  done
  echo "unknown"
}

pkg_count=$(detect_pkgs)
pkg_manager=$(detect_pkg_manager)

nix_pkgs=$(nix profile list 2>/dev/null | grep -c '^Name:' || echo 0)
flat_pkgs=$(flatpak list --columns=app 2>/dev/null | tail -n +1 | wc -l)

CPU_MODEL="$(lscpu 2>/dev/null | awk -F: '/Model name:/ {gsub(/^[ \t]+/,"",$2); print $2; exit}' ||
  awk -F: '/model name/ {gsub(/^[ \t]+/,"",$2); print $2; exit}' /proc/cpuinfo || echo "Unknown")"

GPU_LINE="$(lspci 2>/dev/null | grep -Ei 'VGA|3D|Display' | head -n1 || true)"
if [[ -n "$GPU_LINE" ]]; then
  GPU="${GPU_LINE#*: }"
  GPU="$(printf '%s' "$GPU" |
    sed -E 's/^(VGA compatible controller|3D controller|Display controller)[: ]*//I' |
    sed -E 's/\s*\(rev [^)]+\)//' |
    sed -E 's/^[[:space:]]+|[[:space:]]+$//')"
else
  GPU="Unknown"
fi

RAM_TOTAL="$(free -b 2>/dev/null | awk '/^Mem:/ {printf "%.1f GiB", $2/1024/1024/1024; found=1} END{if(!found) print "Unknown"}')"
DISK_TOTAL="$(df -h / 2>/dev/null | awk 'NR==2 {print $2}' || echo "Unknown")"

build_pkg_string() {
  printf "%s  %s%s%s %s(%s)%s  %s%s%s %s(nix)%s  %s%s%s %s(flatpak)%s" \
    "${yellow}${pkg_icon}" \
    "${fg0}" "${pkg_count}" "${reset}" \
    "${gray}" "${pkg_manager}" "${reset}" \
    "${aqua}" "${nix_pkgs}" "${reset}" \
    "${gray}" "${reset}" \
    "${blue}" "${flat_pkgs}" "${reset}" \
    "${gray}" "${reset}"
}

row() {
  printf '%b%-16s%b %s\n' "$gray" "$1" "$reset" "$2"
}

printf '\n'
row "                "            "${green}${user}${gray}@${yellow}${host}"
row "       .--."                "${red}${os_icon}  ${fg0}${os}"
row "      |o_o |"                "${yellow}${ker_icon}  ${fg0}${kernel}"
row "      |:_/ |"             "${green}${up_icon} ${fg0}${uptime}  ${purple}${inst_icon} ${fg0}${install_days}d"
row "     //   \\ \\"              "$(build_pkg_string)"
row "    (|     | )"             "${blue}${cpu_icon}  ${fg0}${CPU_MODEL}"
row "   /'\\_   _/\`\\"             "${orange}${gpu_icon}  ${fg0}${GPU}"
row "   \\___)=(___/"             "${red}${ram_icon}  ${fg0}${RAM_TOTAL}"
row "                "             "${aqua}${disk_icon}  ${fg0}${DISK_TOTAL}"
printf '%s\n' "$reset"
